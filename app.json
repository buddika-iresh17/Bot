{
  "name": "manisha-ms",
  "description": "WhatsApp Bot using Baileys",
  "repository": "https://github.com/manisha-Official18",
  "keywords": ["whatsapp", "bot", "baileys"],
  "env": {
    "SESSION_ID": {
      "description": "Mega.nz session id for auth credentials file",
      "required": true
    },
    "OWNER_NUMBER": {
      "description": "Owner WhatsApp number with country code",
      "required": true
    },
    "PREFIX": {
      "description": "Bot command prefix",
      "value": "."
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
}